{
  "manifest_version": 3,
  "name": "B站评论学历标签 & 额外倍速",
  "version": "1.2.0",
  "description": "B站增强：(1) 评论区给每位用户随机加学历标签（娱乐用）；(2) 播放器倍速菜单加入 3x/3.5x/4x/5x/10x 等选项，并支持 Alt+数字 快捷切换。",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.bilibili.com/*",
    "https://t.bilibili.com/*",
    "https://search.bilibili.com/*",
    "https://space.bilibili.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.bilibili.com/video/*",
        "https://www.bilibili.com/bangumi/play/*",
        "https://www.bilibili.com/list/*",
        "https://t.bilibili.com/*",
        "https://www.bilibili.com/opus/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://www.bilibili.com/video/*",
        "https://www.bilibili.com/bangumi/play/*",
        "https://www.bilibili.com/list/*",
        "https://www.bilibili.com/medialist/play/*"
      ],
      "js": ["speed.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "B站评论学历标签 & 额外倍速",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
